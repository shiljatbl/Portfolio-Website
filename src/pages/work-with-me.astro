---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const services = [
  'Power BI Report Development',
  'Power BI Service Administration',
  'Data Modelling & Optimisation',
  'Dashboard Audits & Performance Fixes',
];

const steps = [
  { n: '01', title: 'Discovery call', desc: 'We discuss your needs, data sources, and goals.' },
  { n: '02', title: 'Proposal', desc: 'I send a clear scope of work and timeline.' },
  { n: '03', title: 'Development', desc: 'I build and iterate, with regular check-ins.' },
  { n: '04', title: 'Delivery & handover', desc: 'Final report delivered with documentation.' },
];
---

<Layout
  title="Work With Me | Goran Ljiljak"
  description="Hire Goran Ljiljak for Power BI development, data modelling, and dashboard consulting."
>
  <Nav />
  <main class="pt-32 pb-24 px-6">
    <div class="max-w-[800px] mx-auto">

      <!-- Heading -->
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4 tracking-wider uppercase">
        Work With Me
      </h1>

      <!-- Availability -->
      <div class="flex items-center gap-3 mb-10">
        <span class="inline-flex items-center gap-2 bg-[#f7dd30]/10 border border-[#f7dd30]/40 text-[#f7dd30] text-sm font-semibold px-4 py-2 rounded-full tracking-wide">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
          </svg>
          Available for side projects
        </span>
      </div>
      <p class="text-zinc-400 text-lg leading-relaxed mb-16">
        I am currently available for side projects and freelance engagements alongside my main role
        as a Power BI Developer. I take on a small number of projects at a time to ensure quality
        and responsiveness.
      </p>

      <!-- What I Can Help You With -->
      <section class="mb-16">
        <h2 class="font-heading text-2xl font-bold text-white mb-6 tracking-wide uppercase">
          What I Can Help You With
        </h2>
        <ul class="space-y-3">
          {services.map((s) => (
            <li class="flex items-center gap-3 text-zinc-300 text-lg">
              <span class="w-2 h-2 rounded-full bg-[#f7dd30] flex-shrink-0" />
              {s}
            </li>
          ))}
        </ul>
      </section>

      <!-- How I Work -->
      <section class="mb-16">
        <h2 class="font-heading text-2xl font-bold text-white mb-6 tracking-wide uppercase">
          How I Work
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="group relative bg-zinc-900 border border-zinc-800 rounded-xl p-8 overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-yellow-500/60 hover:shadow-[0_0_24px_rgba(247,221,48,0.12)]">
            <div class="absolute top-0 left-0 right-0 h-[3px] bg-[#f7dd30]" />
            <h3 class="font-heading font-semibold text-white text-xl mb-3 tracking-wide group-hover:text-yellow-400 transition-colors">
              Fixed Price
            </h3>
            <p class="text-zinc-400 text-base leading-relaxed">
              Best for well-defined projects with a clear scope. We agree on deliverables and price
              upfront — no surprises. Ideal for report builds, model restructuring, and dashboard
              audits.
            </p>
          </div>
          <div class="group relative bg-zinc-900 border border-zinc-800 rounded-xl p-8 overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-yellow-500/60 hover:shadow-[0_0_24px_rgba(247,221,48,0.12)]">
            <div class="absolute top-0 left-0 right-0 h-[3px] bg-[#f7dd30]" />
            <h3 class="font-heading font-semibold text-white text-xl mb-3 tracking-wide group-hover:text-yellow-400 transition-colors">
              Hourly Rate
            </h3>
            <p class="text-zinc-400 text-base leading-relaxed">
              Best for ongoing support, consulting, or projects where the scope evolves. Billed by
              the hour with regular updates on time spent. Ideal for Power BI Service administration
              and advisory work.
            </p>
          </div>
        </div>
      </section>

      <!-- Typical Project Process -->
      <section class="mb-16">
        <h2 class="font-heading text-2xl font-bold text-white mb-8 tracking-wide uppercase">
          Typical Project Process
        </h2>
        <ol class="space-y-6">
          {steps.map((step) => (
            <li class="flex gap-5 items-start">
              <span class="font-heading text-2xl font-bold text-[#f7dd30] leading-none w-10 flex-shrink-0">
                {step.n}
              </span>
              <div>
                <p class="font-semibold text-white text-lg mb-1">{step.title}</p>
                <p class="text-zinc-400">{step.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <!-- Ready to Start -->
      <section class="border-t border-zinc-800 pt-12">
        <h2 class="font-heading text-2xl font-bold text-white mb-4 tracking-wide uppercase">
          Ready to Start?
        </h2>
        <p class="text-zinc-400 text-lg leading-relaxed mb-8">
          The best way to get started is a short introductory call. Reach out via email or LinkedIn
          and let's see if we're a good fit.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="mailto:goran.ljiljak.dev@outlook.com"
            class="inline-block bg-yellow-500 hover:bg-yellow-400 text-black font-bold px-8 py-3 rounded-lg transition-colors tracking-widest text-sm uppercase"
          >
            Email Me
          </a>
          <a
            href="https://www.linkedin.com/in/goranljiljak"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block border border-zinc-700 hover:border-yellow-500/60 text-zinc-300 hover:text-yellow-400 font-bold px-8 py-3 rounded-lg transition-colors tracking-widest text-sm uppercase"
          >
            Connect on LinkedIn
          </a>
        </div>
      </section>

    </div>
  </main>
  <Footer />
</Layout>
