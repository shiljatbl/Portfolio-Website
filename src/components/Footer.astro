---
const year = new Date().getFullYear();
---

<footer class="py-8 px-6 border-t border-zinc-900">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3 text-zinc-600 text-sm">
    <p>&copy; {year} Goran Ljiljak. All rights reserved.</p>
    <p>
      Built with{' '}
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="text-yellow-600 hover:text-yellow-400 transition-colors"
      >Astro</a>
      {' '}&amp;{' '}
      <a
        href="https://tailwindcss.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-yellow-600 hover:text-yellow-400 transition-colors"
      >Tailwind CSS</a>
    </p>
  </div>
</footer>
