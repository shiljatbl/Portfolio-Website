---
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<section id="blog" class="py-24 px-6 fade-section scroll-mt-20">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-end justify-between mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white">Recent Posts</h2>
      <a href="/blog" class="text-blue-400 hover:text-blue-300 transition-colors text-sm font-medium">
        View all →
      </a>
    </div>

    {
      recentPosts.length === 0 ? (
        <p class="text-slate-500">No posts yet. Check back soon.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {recentPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col bg-slate-800/40 border border-slate-700/50 rounded-xl p-6 hover:border-blue-500/40 transition-colors"
            >
              <p class="text-slate-500 text-xs mb-2">{formatDate(post.data.pubDate)}</p>
              <h3 class="font-heading font-semibold text-white text-base mb-2 group-hover:text-blue-400 transition-colors leading-snug flex-1">
                {post.data.title}
              </h3>
              <p class="text-slate-400 text-sm leading-relaxed line-clamp-3 mb-4">
                {post.data.description}
              </p>
              <div class="flex flex-wrap gap-1.5 mt-auto">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="text-xs bg-slate-800 text-slate-500 px-2 py-0.5 rounded border border-slate-700/60">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>
