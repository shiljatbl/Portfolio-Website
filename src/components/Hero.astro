---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const base = lang === 'en' ? '/' : `/${lang}/`;
---

<section
  id="hero"
  class="relative h-screen flex items-center justify-center px-6 overflow-hidden"
>
  <!-- Nebula glow — purple/blue at center-bottom -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 45% at 50% 90%, rgba(59,49,130,0.15) 0%, transparent 70%);"
  />

  <!-- Warm yellow center glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 55% 45% at 50% 50%, rgba(247,221,48,0.03) 0%, transparent 70%);"
  />

  <div class="relative z-10 max-w-4xl mx-auto text-center">
    <p class="text-yellow-500 font-medium text-xs uppercase tracking-[0.3em] mb-6">
      {t.hero.location}
    </p>
    <h1
      class="font-heading text-5xl sm:text-6xl md:text-7xl font-bold text-white mb-4 leading-tight tracking-wider uppercase"
      style="text-shadow: 0 0 80px rgba(250,204,21,0.18);"
    >
      Goran Ljiljak
    </h1>
    <p class="text-zinc-300 text-xl md:text-2xl font-medium mb-8 tracking-wide">
      {t.hero.tagline}
    </p>
    <div class="flex justify-center mb-8">
      <a
        href="https://learn.microsoft.com/api/credentials/share/en-gb/GoranLjiljak-1952/C28E4DF4DD8F15D1?sharingId=B0E52D9B8EDA0B19"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#f7dd30]/10 border border-[#f7dd30]/40 text-[#f7dd30] hover:bg-[#f7dd30]/20 text-xs font-semibold px-4 py-2 rounded-full tracking-wide transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0">
          <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
        </svg>
        {t.hero.certBadge}
      </a>
    </div>
    <p class="text-zinc-500 text-base md:text-lg italic max-w-2xl mx-auto mb-12 leading-relaxed border-l-2 border-yellow-600/50 pl-5 text-left">
      {t.hero.quote}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={`${base}#experience`}
        class="bg-yellow-500 hover:bg-yellow-400 text-black font-bold px-8 py-3 rounded-lg transition-colors tracking-widest text-sm uppercase"
      >
        {t.hero.viewExperience}
      </a>
      <a
        href={`${base}#contact`}
        class="border border-yellow-600/70 text-yellow-400 hover:bg-yellow-500 hover:text-black font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        {t.hero.contactMe}
      </a>
    </div>
  </div>
</section>
