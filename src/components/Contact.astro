---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="py-24 px-6 bg-zinc-900 fade-section">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6">
      {t.contact.heading}
    </h2>
    <p class="text-zinc-400 text-lg leading-relaxed mb-10">
      {t.contact.intro}
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="mailto:goran.ljiljak.dev@outlook.com"
        class="inline-block bg-yellow-500 hover:bg-yellow-400 text-black font-bold px-8 py-3 rounded-lg transition-colors tracking-widest text-sm uppercase"
      >
        {t.contact.emailBtn}
      </a>
      <a
        href="https://www.linkedin.com/in/goranljiljak"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block border border-zinc-700 hover:border-yellow-500/60 text-zinc-300 hover:text-yellow-400 font-bold px-8 py-3 rounded-lg transition-colors tracking-widest text-sm uppercase"
      >
        {t.contact.linkedinBtn}
      </a>
    </div>
  </div>
</section>
