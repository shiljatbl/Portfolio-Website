---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const workWithMeHref = lang === 'en' ? '/work-with-me' : `/${lang}/work-with-me`;
---

<section id="work-with-me" class="py-24 px-6 bg-zinc-900 fade-section">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-6 tracking-wider uppercase">
      {t.workWithMe.heading}
    </h2>
    <p class="text-zinc-400 text-lg leading-relaxed mb-8">
      {t.workWithMe.para}
    </p>
    <div class="flex justify-center mb-10">
      <span class="inline-flex items-center gap-2 bg-[#f7dd30]/10 border border-[#f7dd30]/40 text-[#f7dd30] text-sm font-semibold px-4 py-2 rounded-full tracking-wide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
        </svg>
        {t.workWithMe.available}
      </span>
    </div>
    <a
      href={workWithMeHref}
      class="inline-block bg-yellow-500 hover:bg-yellow-400 text-black font-bold px-8 py-3 rounded-lg transition-colors tracking-widest text-sm uppercase"
    >
      {t.workWithMe.cta}
    </a>
  </div>
</section>
