---
import { Image } from 'astro:assets';
import profilePhoto from '../assets/profile.svg';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<section id="about" class="py-24 px-6 bg-zinc-900 fade-section">
  <div class="max-w-5xl mx-auto flex flex-col items-center">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-10 text-center">
      {t.about.heading}
    </h2>

    <!-- Profile photo -->
    <div
      class="rounded-full overflow-hidden w-[200px] h-[200px] flex-shrink-0 border-[3px] border-[#f7dd30] mb-10"
      style="box-shadow: 0 8px 32px rgba(0,0,0,0.4);"
    >
      <Image
        src={profilePhoto}
        alt="Goran Ljiljak"
        width={200}
        height={200}
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Bio text -->
    <div class="space-y-6 text-zinc-400 text-lg leading-relaxed text-center max-w-[700px]">
      <p>{t.about.p1}</p>
      <p>{t.about.p2}</p>
      <p>{t.about.p3}</p>
      <p>{t.about.p4}</p>
      <p>{t.about.p5}</p>
    </div>
  </div>
</section>
