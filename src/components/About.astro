---
import { Image } from 'astro:assets';
import profilePhoto from '../assets/profile.svg';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<section id="about" class="py-24 px-6 bg-zinc-900 fade-section">
  <div class="max-w-5xl mx-auto flex flex-col items-center">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-10 text-center">
      {t.about.heading}
    </h2>

    <!-- Profile photo -->
    <div
      class="rounded-full overflow-hidden w-[200px] h-[200px] flex-shrink-0 border-[3px] border-[#f7dd30] mb-10"
      style="box-shadow: 0 8px 32px rgba(0,0,0,0.4);"
    >
      <Image
        src={profilePhoto}
        alt="Goran Ljiljak"
        width={200}
        height={200}
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Bio text -->
    <div class="space-y-6 text-zinc-400 text-lg leading-relaxed text-center max-w-[700px]">
      <p>{t.about.p1}</p>
      <p>{t.about.p2}</p>
      <p>{t.about.p3}</p>
      <p>{t.about.p4}</p>
      <p>{t.about.p5}</p>
    </div>

    <!-- Certification badge -->
    <div class="mt-8">
      <a
        href="https://learn.microsoft.com/api/credentials/share/en-gb/GoranLjiljak-1952/C28E4DF4DD8F15D1?sharingId=B0E52D9B8EDA0B19"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border border-[#f7dd30]/50 text-[#f7dd30] hover:bg-[#f7dd30]/10 text-xs font-semibold px-4 py-2 rounded-full tracking-wide transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 flex-shrink-0">
          <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
        </svg>
        Microsoft Certified - Power BI Data Analyst
      </a>
    </div>
  </div>
</section>
