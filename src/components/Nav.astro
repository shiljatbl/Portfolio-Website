---
const navLinks = [
  { href: '/#about', label: 'About' },
  { href: '/#skills', label: 'Skills' },
  { href: '/#experience', label: 'Experience' },
  { href: '/#contact', label: 'Contact' },
  { href: '/blog', label: 'Blog' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-black/95 backdrop-blur-sm border-b border-zinc-900">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a
      href="/"
      class="font-heading font-semibold text-white text-lg tracking-widest uppercase hover:text-yellow-400 transition-colors"
    >
      Goran Ljiljak
    </a>

    <nav aria-label="Main navigation">
      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-8">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="text-zinc-400 hover:text-yellow-400 transition-colors text-sm font-medium tracking-wider uppercase"
            >
              {label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/Resume.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-yellow-500 hover:bg-yellow-400 text-black font-bold text-sm px-4 py-1.5 rounded tracking-wider uppercase transition-colors"
          >
            Resume
          </a>
        </li>
      </ul>

      <!-- Mobile hamburger -->
      <button
        id="menu-btn"
        class="md:hidden text-zinc-400 hover:text-yellow-400 transition-colors"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="hidden border-t border-zinc-900 md:hidden">
    <ul class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-3">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="block text-zinc-400 hover:text-yellow-400 transition-colors font-medium py-1 uppercase tracking-wider text-sm"
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/Resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-yellow-500 hover:bg-yellow-400 text-black font-bold text-sm px-4 py-1.5 rounded tracking-wider uppercase transition-colors"
        >
          Resume
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const logo = document.querySelector('header a[href="/"]') as HTMLAnchorElement | null;
  logo?.addEventListener('click', (e) => {
    if (window.location.pathname === '/') {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
